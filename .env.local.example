# Copy to .env.local and fill in your values

# Supabase (from Supabase project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# FastAPI backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Admin scheduler/pipeline API key (must match backend PIPELINE_API_KEY)
NEXT_PUBLIC_PIPELINE_API_KEY=change-me-to-a-random-secret

# Stripe (publishable key only — keep secret key in backend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
